{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/dist/**/*",
			"!**/.vite-inspect/**/*",
			"!**/test/test-results.json"
		]
	}
}
